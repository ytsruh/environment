{
	"$schema": "https://opencode.ai/config.json",
	"enabled_providers": ["opencode", "opencode-go", "openrouter", "google"],
	"plugin": ["opencode-gemini-auth@latest"],
	"provider": {},
	"autoupdate": true,
	"permission": {
		"edit": "ask",
		"bash": "ask"
	},
	// Custom agents
	"agent": {
		"docs-writer": {
			"description": "Writes and maintains project documentation",
			"mode": "subagent",
			"tools": {
				"bash": false
			},
			"prompt": "You are a technical writer. Create clear, comprehensive documentation.\nFocus on:\n- Clear explanations\n- Proper structure\n- Code examples\n- User-friendly language"
		}
	},
	// MCP Servers
	"mcp": {
		"pencil": {
			"command": [
				"/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
				"--app",
				"desktop"
			],
			"enabled": true,
			"type": "local"
		}
	}
}
